# Copy this file to .kamal/secrets (gitignored) and fill in the values.
#
# Generate APP_KEY:  php artisan key:generate --show
# Generate secrets:  openssl rand -base64 32

KAMAL_REGISTRY_PASSWORD=your-dockerhub-password

APP_KEY=base64:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

DB_PASSWORD=choose-a-strong-password
POSTGRES_PASSWORD=choose-a-strong-password   # must match DB_PASSWORD

REVERB_APP_SECRET=choose-a-strong-secret
